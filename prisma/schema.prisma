generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────
enum Role {
  USER
  ADMIN
}

enum GroupMemberRole {
  LEADER
  MEMBER
}

// ─── Models ──────────────────────────────────────────────
model User {
  id                String         @id @default(uuid())
  email             String         @unique
  passwordHash      String
  name              String?
  image             String?
  country           String?         @default("Việt Nam")
  phone             String?
  twoFactorEnabled  Boolean         @default(false)
  twoFactorMethod   String?         @default("EMAIL")
  role              Role           @default(USER)
  emailVerified     Boolean         @default(false)
  emailVerifiedAt   DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  travelDNA         Json?
  // Phase 21: Bank info for secure QR generation
  bankName          String?
  bankCode          String?
  bankAccountNumber String?
  bankAccountName   String?

  trips              Trip[]
  groupMembers       GroupMember[]
  expensesPaid       Expense[]      @relation("PayerExpenses")
  expenseShares      ExpenseShare[]
  notifications      Notification[]
  journalEntries     JournalEntry[]
  payerSettlements   Settlement[]   @relation("PayerSettlements")
  receiverSettlements Settlement[]  @relation("ReceiverSettlements")

  // Phase 23: Gamification & Economy
  points            Int             @default(500)
  inventory         Json?           @default("[]")
  lastActiveTripId  String?
  lastActiveAt      DateTime        @default(now())

  // Phase 24: Real 2FA (Real Email/SMS)
  verificationCode  String?
  codeExpires       DateTime?

  // Phase 25: Social Hub & Messenger
  sentRequests      Friendship[]   @relation("SentRequests")
  receivedRequests  Friendship[]   @relation("ReceivedRequests")
  conversations     Conversation[] @relation("UserConversations")
  messages          Message[]

  // Security & Admin
  blocksSent        Block[]        @relation("Blocker")
  blocksReceived    Block[]        @relation("Blocked")
  reportsSent       Report[]       @relation("Reporter")
  reportsReceived   Report[]       @relation("Reported")

  // Ban System
  bannedUntil       DateTime?
  banReason         String?

  // Privilege & Privacy Settings
  acceptMessages     Boolean         @default(true)
  profileVisibility  String          @default("PUBLIC") 

  // Notification Settings
  emailNotifications Boolean         @default(true)
  pushNotifications  Boolean         @default(true)

  // Forgot Password
  resetToken        String?         @unique
  resetTokenExpires DateTime?
}

model Place {
  id              String     @id @default(uuid())
  name            String
  lat             Float
  lng             Float
  category        String     // STAY, EAT, PLAY
  estimatedCost   Float?
  durationMinutes Int?

  tripItems       TripItem[]
}

model Trip {
  id           String        @id @default(uuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  createdAt    DateTime      @default(now())
  budget       Float?
  startDate    DateTime?
  endDate      DateTime?
  city         String?
  intent       String?
  cityWiki     String?
  estimatedBudget Float?
  // Phase 21: Invite system
  inviteCode   String?       @unique

  tripItems    TripItem[]
  expenses     Expense[]
  groupMembers GroupMember[]
  journalEntries JournalEntry[]
  settlements  Settlement[]
}

model Settlement {
  id          String   @id @default(uuid())
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  payerId     String
  payer       User     @relation("PayerSettlements", fields: [payerId], references: [id], onDelete: Cascade)
  receiverId  String
  receiver    User     @relation("ReceiverSettlements", fields: [receiverId], references: [id], onDelete: Cascade)
  amount      Float
  receiptUrl  String?
  status      String   @default("PENDING") // PENDING, COMPLETED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Phase 21: Many-to-many pivot for Trip members
model GroupMember {
  id       String          @id @default(uuid())
  tripId   String
  trip     Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  userId   String
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     GroupMemberRole @default(MEMBER)
  joinedAt DateTime        @default(now())

  @@unique([tripId, userId])
}

model TripItem {
  id         String    @id @default(uuid())
  tripId     String
  trip       Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  placeId    String
  place      Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  date       DateTime?
  orderIndex Int
}

model Expense {
  id          String         @id @default(uuid())
  tripId      String
  trip        Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  title       String
  createdAt   DateTime       @default(now())
  totalAmount Float
  payerId     String
  payer       User           @relation("PayerExpenses", fields: [payerId], references: [id], onDelete: Cascade)

  shares      ExpenseShare[]
}

model ExpenseShare {
  id             String  @id @default(uuid())
  expenseId      String
  expense        Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  userId         String
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountOwed     Float
  // Phase 21: Track settlement confirmation
  settlementPaid Boolean @default(false)
}

// Tier 3: In-app notifications
model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  isRead    Boolean  @default(false)
  link      String?  // Optional deeplink e.g. /split-bill?tripId=xxx
  createdAt DateTime @default(now())
}

// Tier 4: Geo-Journal entries with Cloudinary image
model JournalEntry {
  id          String   @id @default(uuid())
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lat         Float
  lng         Float
  textContent String?
  imageUrl    String   // Cloudinary secure_url
  createdAt   DateTime @default(now())
}

// Phase 25: Social Hub & Messenger Models
model Friendship {
  id          String   @id @default(uuid())
  senderId    String
  sender      User     @relation("SentRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId  String
  receiver    User     @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)
  status      String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([senderId, receiverId])
}

model Conversation {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  messages  Message[]
  users     User[]    @relation("UserConversations")
  clearedAt Json?     // Structure: {"userId": "ISO_DATE_STRING"}
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String
  type           String       @default("TEXT") // TEXT, IMAGE, AUDIO
  fileUrl        String?      // Cloudinary URL for media
  createdAt      DateTime     @default(now())

  // Reply functionality
  replyToId      String?
  replyTo        Message?     @relation("MessageReplies", fields: [replyToId], references: [id])
  replies        Message[]    @relation("MessageReplies")
  
  // Deletion tracking
  deletedFor     String[]     @default([])
}

model Block {
  id        String   @id @default(uuid())
  blockerId String
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
}

model Report {
  id             String   @id @default(uuid())
  reporterId     String
  reporter       User     @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedId     String
  reported       User     @relation("Reported", fields: [reportedId], references: [id], onDelete: Cascade)
  conversationId String?
  reason         String
  content        String?
  proofImage     String?
  status         String   @default("PENDING") // PENDING, RESOLVED, DISMISSED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
model SystemConfig {
  id                 String   @id @default("GLOBAL_CONFIG")
  siteName           String   @default("OptiRoute AI")
  maintenanceMode    Boolean  @default(false)
  allowRegistration  Boolean  @default(true)
  supportEmail       String?  @default("support@optiroute.ai")
  adminNotifications Boolean  @default(true)
  updatedAt          DateTime @updatedAt
}

model DeletedAccountRecord {
  id        String   @id @default(uuid())
  email     String   @unique
  reason    String
  adminName String?
  deletedAt DateTime @default(now())
}

model ItineraryCache {
  id           String   @id @default(uuid())
  promptHash   String   @unique
  query        String
  city         String
  intentData   Json     // Stores { city, budget, themes, suggested_places, cost_breakdown }
  createdAt    DateTime @default(now())
  expiresAt    DateTime
}
